{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Server=localhost;Port=5433;Database=trustscore;User Id=trustscore;Password=trustscore;",
    "Redis": "localhost:6379"
  },
  "SeedProbe": {
    "Enabled": true,
    "AgentDid": "did:web:trustscoreagent.com:probe",
    "TimeoutSeconds": 10,
    "Targets": [
      { "Service": "api.open-meteo.com", "Url": "https://api.open-meteo.com/v1/forecast?latitude=48.85&longitude=2.35&current=temperature_2m", "ExpectField": "current" },
      { "Service": "api.frankfurter.app", "Url": "https://api.frankfurter.app/latest?base=EUR&symbols=USD", "ExpectField": "rates" },
      { "Service": "restcountries.com", "Url": "https://restcountries.com/v3.1/name/france?fields=name", "ExpectField": "name" },
      { "Service": "en.wikipedia.org", "Url": "https://en.wikipedia.org/api/rest_v1/page/summary/Artificial_intelligence", "ExpectField": "extract" },
      { "Service": "www.wikidata.org", "Url": "https://www.wikidata.org/wiki/Special:EntityData/Q42.json", "ExpectField": "entities" },
      { "Service": "openlibrary.org", "Url": "https://openlibrary.org/search.json?q=lord+of+the+rings&limit=1&fields=key,title", "ExpectField": "numFound" },
      { "Service": "date.nager.at", "Url": "https://date.nager.at/api/v3/PublicHolidays/2026/FR", "ExpectField": null },
      { "Service": "hacker-news.firebaseio.com", "Url": "https://hacker-news.firebaseio.com/v0/item/1.json", "ExpectField": "id" },
      { "Service": "earthquake.usgs.gov", "Url": "https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson&limit=1", "ExpectField": "features" },
      { "Service": "api.github.com", "Url": "https://api.github.com/zen", "ExpectField": null },
      { "Service": "httpbin.org", "Url": "https://httpbin.org/get", "ExpectField": "url" },
      { "Service": "api.coingecko.com", "Url": "https://api.coingecko.com/api/v3/ping", "ExpectField": "gecko_says" }
    ]
  }
}
